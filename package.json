{
  "name": "vector-sidebar",
  "version": "0.2.1",
  "description": "Semantic vector search for Obsidian vaults",
  "main": "main.js",
  "scripts": {
    "build": "node esbuild.config.mjs",
    "dev": "node esbuild.config.mjs --watch",
    "lint": "eslint src/",
    "fmt": "prettier --write 'src/**/*.ts' 'scripts/**/*.mjs' '*.md' '*.json' '*.mjs'",
    "fmt:check": "prettier --check 'src/**/*.ts' 'scripts/**/*.mjs' '*.md' '*.json' '*.mjs'",
    "typecheck": "tsc --noEmit",
    "check": "npm run typecheck && npm run lint && npm run fmt:check",
    "index": "node scripts/index.mjs",
    "deploy": "npm run build && node scripts/deploy.mjs"
  },
  "dependencies": {
    "@huggingface/transformers": "^3.4.0",
    "@orama/orama": "^3.1.18"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "esbuild": "^0.25.0",
    "eslint": "^9.0.0",
    "obsidian": "latest",
    "prettier": "^3.8.1",
    "typescript": "^5.4.0",
    "typescript-eslint": "^8.0.0"
  }
}
